# انسخ هذا الملف إلى .env (مستثنى من git بـ .gitignore) للتشغيل المحلي،
# أو أضف نفس المتغيرات كـ Environment Variables بإعدادات الـ Pod/Template على RunPod.
# لا تكتب أي قيمة حقيقية هنا أو بأي ملف .py — هذا الملف قالب فقط بدون أسرار.

# --- Hugging Face --- (مطلوب: Gemma موديل بوابة gated، والمستودع المدموج قد يكون خاصاً)
# ولّده من https://huggingface.co/settings/tokens (صلاحية Read تكفي)
HF_TOKEN=

# --- أداة البحث بالإنترنت (app/tools/web_search.py) --- بدون مفتاح
# تستخدم DuckDuckGo عبر مكتبة ddgs — ما تحتاج أي إعداد هنا.

# --- الموديل (النسخة المدموجة: base + LoRA اللهجة العراقية مندمجين بالأوزان) ---
# يقرأه start.sh (يمرره لـ vllm serve) وapp/config.py (اسم الموديل بالطلبات)
# MODEL_NAME=ameer4wisam/gemma-iraqi-finetune-v2

# --- خادم vLLM (انظر start.sh وapp/engine.py) ---
# عنوان الخادم من جهة الباك اند — غيّره فقط لو شغّلت vLLM بمنفذ/جهاز مختلف.
# ⚠️ VLLM_BASE_URL وVLLM_PORT لازم يتطابقان دائماً (نفس رقم المنفذ) —
# start.sh يشغّل vLLM على VLLM_PORT، وapp/engine.py يتصل بـ VLLM_BASE_URL،
# وهما إعدادان منفصلان بدون ربط تلقائي بينهما.
# VLLM_BASE_URL=http://127.0.0.1:18001/v1
# VLLM_PORT=18001
# MAX_MODEL_LEN=4096
# GPU_MEMORY_UTILIZATION=0.90

# --- تحويل الصوت لنص (ميزة order_intake — يعمل داخل FastAPI، مو عبر vLLM) ---
# WHISPER_MODEL=ayoubkirouane/whisper-small-ar
